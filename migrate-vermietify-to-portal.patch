+                    MwSt. ({invoice.tax_rate}%)
+                  </span>
+                  <span>{formatCurrency(invoice.tax_cents / 100)}</span>
+                </div>
+                <Separator />
+                <div className="flex justify-between font-bold text-lg">
+                  <span>Gesamt</span>
+                  <span>{formatCurrency(invoice.total_cents / 100)}</span>
+                </div>
+              </div>
+            </div>
+          </CardContent>
+        </Card>
+      </div>
+    </MainLayout>
+  );
+}
diff --git a/apps/vermietify/src/pages/finance/InvoiceList.tsx b/apps/vermietify/src/pages/finance/InvoiceList.tsx
new file mode 100644
