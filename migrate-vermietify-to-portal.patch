+                <h2 className="text-lg font-semibold">
+                  {categoryLabels[category] || category}
+                </h2>
+                <Badge variant="secondary">{mods.length}</Badge>
+              </div>
+              <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
+                {mods.map((mod) => {
+                  const Icon = mod.icon;
+                  return (
+                    <Card
+                      key={mod.id}
+                      className={mod.enabled ? "" : "opacity-60"}
+                    >
+                      <CardHeader className="pb-3">
+                        <div className="flex items-start justify-between">
+                          <div className="flex items-center gap-3">
+                            <div
+                              className={`rounded-lg p-2 ${
+                                mod.enabled
+                                  ? "bg-primary/10"
+                                  : "bg-muted"
+                              }`}
+                            >
+                              <Icon
+                                className={`h-5 w-5 ${
+                                  mod.enabled
+                                    ? "text-primary"
+                                    : "text-muted-foreground"
+                                }`}
+                              />
+                            </div>
+                            <div>
+                              <CardTitle className="text-sm flex items-center gap-2">
+                                {mod.name}
+                                {mod.premium && (
+                                  <Badge className="bg-gradient-to-r from-amber-400 to-amber-600 text-white text-[10px] px-1.5 py-0">
+                                    <Crown className="h-3 w-3 mr-0.5" />
+                                    Premium
+                                  </Badge>
+                                )}
+                              </CardTitle>
+                            </div>
+                          </div>
+                          <Switch
+                            checked={mod.enabled}
+                            onCheckedChange={() => handleToggleModule(mod.id)}
+                          />
+                        </div>
+                      </CardHeader>
+                      <CardContent>
+                        <CardDescription>{mod.description}</CardDescription>
+                      </CardContent>
+                    </Card>
+                  );
