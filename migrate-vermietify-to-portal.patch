+function getBaujahrsKategorie(baujahr: number): string {
+  if (baujahr < 1949) return "vor1949";
+  if (baujahr <= 1978) return "1949-1978";
+  if (baujahr <= 1990) return "1979-1990";
+  if (baujahr <= 2002) return "1991-2002";
