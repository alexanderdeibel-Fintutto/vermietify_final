+                  </div>
+                </CardHeader>
+                <CardContent className="space-y-4">
+                  {/* Score Bar */}
+                  <div className="flex items-center gap-4">
+                    <Progress value={area.score} className="h-3 flex-1" />
+                    <span className="text-lg font-bold w-14 text-right">{area.score}%</span>
