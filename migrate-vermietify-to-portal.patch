+      status: isPast ? "paid" : isCurrent ? "pending" : "pending",
+      reference: `NK-${year}-${String(month + 1).padStart(2, "0")}`,
+    });
+  }
+
+  // Add deposit for 2025
+  if (year === 2025) {
+    payments.unshift({
+      id: "deposit-2025",
+      date: "2025-01-15",
+      amount: 2550.0,
+      type: "Kaution",
+      status: "paid",
+      reference: "KAUTION-2025",
+    });
+  }
