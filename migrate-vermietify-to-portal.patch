+export default function MietpreisBremsechecker() {
+  const [plz, setPlz] = useState("");
+  const [stadt, setStadt] = useState("");
+  const [wohnflaeche, setWohnflaeche] = useState(0);
+  const [baujahr, setBaujahr] = useState(0);
