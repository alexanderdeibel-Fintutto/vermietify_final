+  { key: "contract", label: "Verträge", icon: FileText, color: "text-purple-600", bgColor: "bg-purple-100" },
+  { key: "tax", label: "Steuern", icon: Calculator, color: "text-orange-600", bgColor: "bg-orange-100" },
