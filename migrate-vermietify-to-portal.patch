+                    <Bot className="h-4 w-4 text-blue-600" />
+                  </div>
+                )}
+                <div
+                  className={cn(
+                    "max-w-[70%] rounded-lg px-4 py-3 text-sm",
+                    msg.role === "user"
+                      ? "bg-primary text-primary-foreground"
+                      : "bg-muted"
+                  )}
+                >
+                  <div className="whitespace-pre-wrap">{msg.content}</div>
