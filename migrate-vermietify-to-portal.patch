+                  min={0}
+                  max={10}
+                  step={0.01}
+                />
+                <p className="text-xs text-muted-foreground">
+                  Typisch: 3,57% (inkl. MwSt.) je Kauferseite
+                </p>
+              </div>
+            </CardContent>
+          </Card>
+
+          {/* Results Card */}
+          <Card>
+            <CardHeader>
+              <CardTitle className="text-lg">Gesamtkosten</CardTitle>
+            </CardHeader>
+            <CardContent>
+              <Table>
