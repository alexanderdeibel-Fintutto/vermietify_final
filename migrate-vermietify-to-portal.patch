+           newNotices.push({
+             submissionId: submission.id,
+             noticeDate: new Date().toISOString().split("T")[0],
+             assessedTax,
+             declaredTax,
+             difference,
+           });
+         }
+       }
+     }
+ 
+     return new Response(
+       JSON.stringify({
