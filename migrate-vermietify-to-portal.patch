+                </div>
+                <div>
+                  <p className="text-2xl font-bold">{enabledCount}</p>
+                  <p className="text-sm text-muted-foreground">Aktiviert</p>
+                </div>
+              </div>
+            </CardContent>
+          </Card>
+          <Card>
+            <CardContent className="p-6">
