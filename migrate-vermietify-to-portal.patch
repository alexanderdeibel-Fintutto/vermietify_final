+                  variant="outline"
+                  size="sm"
+                  className="mt-3"
+                  onClick={openEditDialog}
+                >
+                  Notiz hinzufügen
+                </Button>
+              </div>
+            )}
+          </CardContent>
+        </Card>
+
+        {/* Tax Info */}
+        <Card>
+          <CardHeader>
+            <CardTitle className="flex items-center gap-2">
+              <FileText className="h-5 w-5" />
+              Steuerinformationen
+            </CardTitle>
+          </CardHeader>
+          <CardContent>
+            <div className="grid gap-4 md:grid-cols-3">
