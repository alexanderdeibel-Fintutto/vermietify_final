+
+            {/* Nettomietrendite */}
+            <Card className="border-primary/20">
+              <CardContent className="p-6">
+                <p className="text-sm text-muted-foreground">Nettomietrendite</p>
+                <p className="text-4xl font-bold text-primary mt-1">
