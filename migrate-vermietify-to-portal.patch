+
+interface CategoryConfig {
+  key: string;
+  label: string;
+  icon: typeof Shield;
+  color: string;
+  bgColor: string;
+}
+
+const CATEGORIES: CategoryConfig[] = [
+  { key: "dsgvo", label: "DSGVO", icon: Lock, color: "text-blue-600", bgColor: "bg-blue-100" },
