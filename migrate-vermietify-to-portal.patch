+      first_name: owner.first_name,
+      last_name: owner.last_name,
+      email: owner.email,
+      phone: owner.phone,
+      address: owner.address,
+      tax_number: owner.tax_number,
+      bank_iban: owner.bank_iban,
+      bank_bic: owner.bank_bic,
