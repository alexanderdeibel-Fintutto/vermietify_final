+                          <p className="text-sm text-muted-foreground">
+                            {widget.title} - Vorschau
+                          </p>
+                          <p className="text-xs text-muted-foreground mt-1">
+                            Daten: {DATA_SOURCES.find((d) => d.value === widget.data_source)?.label}
+                          </p>
+                        </div>
+                      )}
+                    </CardContent>
+                  </Card>
+                );
+              })
+            )}
+          </div>
+        </div>
+      </div>
+    </MainLayout>
+  );
+}
