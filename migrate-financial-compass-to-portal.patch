++            </Button>
++          </div>
++        ))}
++      </div>
++
++      {/* Main FAB button */}
++      <Button
++        size="icon"
++        className={cn(
++          'h-14 w-14 rounded-full shadow-lg transition-all duration-300',
++          isOpen
++            ? 'bg-muted-foreground hover:bg-muted-foreground/90 rotate-45'
