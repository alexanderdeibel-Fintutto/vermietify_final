++  onUploadReceipt,
++  onScanReceipt,
++}: FloatingActionButtonProps) {
++  const [isOpen, setIsOpen] = useState(false);
++
++  const actions = [
++    {
++      icon: BookOpen,
++      label: 'Buchung',
++      onClick: onNewBooking,
++      color: 'bg-blue-500 hover:bg-blue-600',
++    },
